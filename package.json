{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "echo 'Run npm run test:all for complete test suite'",
    "test:all": "node src/app/tests/TestOrchestrator.ts all",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:regression": "node src/app/tests/TestOrchestrator.ts regression",
    "test:regression:auth": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Authentication'",
    "test:regression:mpi": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Master Patient Index'",
    "test:regression:clinical": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Clinical Documentation'",
    "test:regression:pharmacy": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Pharmacy'",
    "test:regression:lab": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Laboratory'",
    "test:regression:queue": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Queue'",
    "test:regression:reporting": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Ministry'",
    "test:regression:fhir": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'FHIR'",
    "test:regression:i18n": "jest src/app/tests/AutomatedRegressionSuite.test.ts -t 'Language'",
    "test:regression:report": "jest src/app/tests/AutomatedRegressionSuite.test.ts --json --outputFile=test-results/regression/report.json",
    "test:load": "node src/app/tests/LoadStressTests.ts",
    "test:load:district": "node src/app/tests/LoadStressTests.ts district",
    "test:load:regional": "node src/app/tests/LoadStressTests.ts regional",
    "test:load:spike": "node src/app/tests/LoadStressTests.ts spike",
    "test:load:2g": "node src/app/tests/LoadStressTests.ts 2g",
    "test:load:offline-sync": "node src/app/tests/LoadStressTests.ts offline-sync",
    "test:load:validate-thresholds": "node src/app/tests/LoadStressTests.ts validate",
    "test:security": "node src/app/tests/SecurityPenetrationTests.ts",
    "test:security:sql-injection": "jest src/app/tests/SecurityPenetrationTests.ts -t 'SQL Injection'",
    "test:security:xss": "jest src/app/tests/SecurityPenetrationTests.ts -t 'XSS'",
    "test:security:jwt": "jest src/app/tests/SecurityPenetrationTests.ts -t 'JWT'",
    "test:security:privilege-escalation": "jest src/app/tests/SecurityPenetrationTests.ts -t 'Privilege Escalation'",
    "test:security:rate-limiting": "jest src/app/tests/SecurityPenetrationTests.ts -t 'Rate Limit'",
    "test:security:brute-force": "jest src/app/tests/SecurityPenetrationTests.ts -t 'Brute Force'",
    "test:security:csrf": "jest src/app/tests/SecurityPenetrationTests.ts -t 'CSRF'",
    "test:security:path-traversal": "jest src/app/tests/SecurityPenetrationTests.ts -t 'Path Traversal'",
    "test:security:report": "node src/app/tests/SecurityPenetrationTests.ts --report",
    "validate:data-integrity": "node src/app/tests/DataIntegrityValidator.ts",
    "validate:orphan-records": "node src/app/tests/DataIntegrityValidator.ts orphans",
    "validate:foreign-keys": "node src/app/tests/DataIntegrityValidator.ts foreign-keys",
    "validate:inventory": "node src/app/tests/DataIntegrityValidator.ts inventory",
    "validate:mpi-duplicates": "node src/app/tests/DataIntegrityValidator.ts mpi",
    "validate:audit-trail": "node src/app/tests/DataIntegrityValidator.ts audit",
    "test:ci": "node src/app/tests/TestOrchestrator.ts ci",
    "test:unit": "jest --testMatch='**/*.unit.test.ts'",
    "test:integration": "jest --testMatch='**/*.integration.test.ts'",
    "test:fhir:patient-schema": "jest src/app/tests/FHIRTests.test.ts -t 'Patient Resource'",
    "test:fhir:encounter-schema": "jest src/app/tests/FHIRTests.test.ts -t 'Encounter Resource'",
    "test:fhir:observation-schema": "jest src/app/tests/FHIRTests.test.ts -t 'Observation Resource'",
    "test:fhir:medication-schema": "jest src/app/tests/FHIRTests.test.ts -t 'MedicationRequest'",
    "test:fhir:search-params": "jest src/app/tests/FHIRTests.test.ts -t 'Search Parameters'",
    "test:fhir:oauth": "jest src/app/tests/FHIRTests.test.ts -t 'OAuth'",
    "test:fhir:rate-limit": "jest src/app/tests/FHIRTests.test.ts -t 'Rate Limit'",
    "test:i18n:completeness": "jest src/app/tests/I18nTests.test.ts -t 'Translation Completeness'",
    "test:i18n:missing-keys": "jest src/app/tests/I18nTests.test.ts -t 'Missing Keys'",
    "test:i18n:icu-validation": "jest src/app/tests/I18nTests.test.ts -t 'ICU'",
    "test:i18n:switching": "jest src/app/tests/I18nTests.test.ts -t 'Language Switching'",
    "test:i18n:hardcoded-text": "jest src/app/tests/I18nTests.test.ts -t 'Hardcoded Text'",
    "i18n:audit": "node src/tools/translationAuditor.ts",
    "i18n:scan-hardcoded": "grep -rn 'Emergency\\|Doctor\\|Patient\\|Appointment\\|Symptom' src/app/components/ --include='*.tsx' || true",
    "i18n:validate-all": "node scripts/translationGate.cjs",
    "i18n:gate": "node scripts/translationGate.cjs",
    "test:e2e:language-switching": "playwright test src/app/tests/e2e/languageSwitching.spec.ts",
    "test:e2e:language-visual": "playwright test src/app/tests/e2e/languageSwitching.spec.ts --grep 'Visual'",
    "test:e2e:language-a11y": "playwright test src/app/tests/e2e/languageSwitching.spec.ts --grep 'Accessibility'",
    "test:generate-data": "node src/app/tests/TestDataGenerator.ts",
    "test:generate-data:patients": "node src/app/tests/TestDataGenerator.ts patients 100",
    "test:generate-data:hospital-day": "node src/app/tests/TestDataGenerator.ts hospital-day 500",
    "test:generate-data:edge-cases": "node src/app/tests/TestDataGenerator.ts edge-cases",
    "test:generate-data:stress": "node src/app/tests/TestDataGenerator.ts stress-test",
    "test:dashboard": "vite --open /test-results",
    "test:report:html": "jest --coverage --coverageReporters=html",
    "test:report:json": "jest --json --outputFile=test-results/results.json",
    "test:report:pdf": "node scripts/generatePDFReport.js",
    "test:check-threshold": "node scripts/checkDeploymentThresholds.js",
    "test:generate-compliance-report": "node scripts/generateComplianceReport.js",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "security:sast": "echo 'Run SAST scan'",
    "db:test:setup": "echo 'Setup test database'",
    "db:test:seed": "echo 'Seed test data'",
    "db:test:reset": "echo 'Reset test database'",
    "db:test:ping": "echo 'Ping database'",
    "db:migrations:validate": "echo 'Validate migrations'",
    "deploy:check-env-vars": "node scripts/checkEnvVars.js",
    "deploy:generate-report": "node scripts/generateDeploymentReport.js",
    "deploy:production": "echo 'Deploy to production'",
    "monitor:health-check": "node src/app/tests/MonitoringAlertingSystem.ts health",
    "notify:moh-team": "node scripts/notifyMoHTeam.js",
    "server:test": "vite --mode test",
    "smoke:production": "echo 'Run production smoke tests'"
  },
  "dependencies": {
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@supabase/supabase-js": "^2.97.0",
    "@types/crypto-js": "^4.2.2",
    "@xenova/transformers": "^2.17.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "firebase": "^12.15.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.42.2",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-i18next": "^16.5.4",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router-dom": "^7.12.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.3.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2"
    }
  }
}
